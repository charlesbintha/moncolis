# =============================================================================
# COLISN BACKEND - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================================

# --- APPLICATION ---
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
APP_NAME=ColiSN
APP_VERSION=1.0.0

# --- BASE DE DONNÉES PostgreSQL ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/colisn_db

# --- REDIS (Cache & Sessions) ---
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379

# --- JWT (JSON Web Tokens) ---
# Générez des secrets forts : openssl rand -base64 64
JWT_SECRET=votre_jwt_secret_tres_long_et_securise_ici
JWT_REFRESH_SECRET=votre_refresh_secret_different_du_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- CLOUDINARY (Stockage d'images) ---
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret
CLOUDINARY_FOLDER=colisn

# --- AFRICAS TALKING (SMS / OTP) ---
# https://account.africastalking.com/apps/sandbox/settings/key
AFRICAS_TALKING_API_KEY=votre_api_key_africas_talking
AFRICAS_TALKING_USERNAME=votre_username
# En sandbox, utiliser: sandbox
# En production, utiliser votre username AT

# --- PAYDUNYA (Wave + Orange Money) ---
# https://paydunya.com/developers
PAYDUNYA_MASTER_KEY=votre_master_key
PAYDUNYA_PRIVATE_KEY=votre_private_key
PAYDUNYA_TOKEN=votre_token
PAYDUNYA_MODE=test
# Valeurs: test | live

# --- STRIPE (Paiement carte pour la diaspora) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_votre_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_votre_webhook_secret

# --- FIREBASE (Push Notifications) ---
# Téléchargez le fichier JSON depuis Firebase Console > Project Settings > Service Accounts
# Encodez-le en base64 : base64 -i serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# Ou utilisez le chemin du fichier :
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# --- COMMISSION PLATEFORME ---
PLATFORM_COMMISSION_RATE=0.12
# 12% de commission sur chaque transaction

# --- OTP CONFIGURATION ---
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# --- BOOKING CONFIGURATION ---
BOOKING_ACCEPT_DEADLINE_HOURS=2
REVIEW_DEADLINE_HOURS=72
DISPUTE_WINDOW_HOURS=48

# --- RATE LIMITING ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
OTP_THROTTLE_TTL=600000
OTP_THROTTLE_LIMIT=3

# --- ADMIN ---
ADMIN_PHONE=+221XXXXXXXXX
ADMIN_PASSWORD=admin_password_securise

# --- LOGS ---
LOG_LEVEL=debug
# Valeurs: error | warn | info | http | debug

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
