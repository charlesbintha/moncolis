{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["src/*"],
      "@auth/*": ["src/auth/*"],
      "@users/*": ["src/users/*"],
      "@trips/*": ["src/trips/*"],
      "@parcels/*": ["src/parcels/*"],
      "@bookings/*": ["src/bookings/*"],
      "@payments/*": ["src/payments/*"],
      "@reviews/*": ["src/reviews/*"],
      "@disputes/*": ["src/disputes/*"],
      "@admin/*": ["src/admin/*"],
      "@notifications/*": ["src/notifications/*"],
      "@common/*": ["src/common/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "prisma", "test", "**/*.spec.ts"]
}
